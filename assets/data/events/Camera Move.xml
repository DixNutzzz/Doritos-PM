<!DOCTYPE doritos-event>
<event>

	<!-- ____________________________ Event Settings ____________________________ -->

	<description>Move camera to selected position</description>

	<!-- _________________________________ Params _______________________________ -->

	<param name="Character Index" type="int" optional="true"/>

	<param name="Force X" type="float" optional="true" if="params[0] == null"/>
	<param name="Force Y" type="float" optional="true" if="params[0] == null"/>

</event>
